[package]
name = "meu-mini-ide"
version = "0.1.0"
edition = "2021"

[dependencies]
# Web e Async
axum = { version = "0.7", features = ["ws"] }
tokio = { version = "1.0", features = ["full"] }
tower-http = { version = "0.5", features = ["fs"] }

# JSON
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

# Terminal Real
portable-pty = "0.8"
futures-util = "0.3"
